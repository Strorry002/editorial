generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// COUNTRY — Core entity
// ============================================================================

model Country {
  id          String   @id @default(uuid())
  code        String   @unique          // ISO 3166-1 alpha-2 (US, CA, UK, AU, DE)
  name        String
  region      String                    // north-america, europe, oceania, etc.
  languages   String[]                  // ["en", "fr"]
  currency    String                    // USD, CAD, GBP, etc.
  capitalCity String?
  flag        String?                   // 🇺🇸
  timezone    String?                   // America/New_York
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  visaPrograms     VisaProgram[]
  laborRegulations LaborRegulation[]
  costOfLiving     CostOfLiving[]
  statistics       Statistic[]
  legalUpdates     LegalUpdate[]
  cities           City[]

  @@index([region])
}

// ============================================================================
// VISA PROGRAMS — Work, student, tourist, DN, investment, family, asylum
// ============================================================================

model VisaProgram {
  id              String    @id @default(uuid())
  countryCode     String
  type            String    // work, student, tourist, investment, digital_nomad, family, asylum, refugee
  name            String    // "H-1B Specialty Occupation", "Express Entry", etc.
  description     String?
  requirements    Json      @default("{}") // { documents: [], conditions: [], income_threshold: 0, fees: {} }
  processingTime  String?   // "3-6 months"
  duration        String?   // "3 years"
  renewability    String?   // "renewable once", "unlimited"
  quotaInfo       String?   // "85,000/year"
  approvalRate    Float?    // 0.72 = 72%
  officialUrl     String?
  lastVerified    DateTime?
  isActive        Boolean   @default(true)
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  country Country @relation(fields: [countryCode], references: [code])

  @@index([countryCode])
  @@index([type])
  @@index([countryCode, type])
}

// ============================================================================
// LABOR REGULATIONS — Wages, permits, taxes, diploma recognition, rights
// ============================================================================

model LaborRegulation {
  id              String    @id @default(uuid())
  countryCode     String
  category        String    // minimum_wage, work_permits, income_tax, diploma_recognition, worker_rights, social_security
  title           String
  content         Json      @default("{}") // structured data per category
  effectiveDate   DateTime?
  sourceUrl       String?
  lastVerified    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  country Country @relation(fields: [countryCode], references: [code])

  @@index([countryCode])
  @@index([category])
  @@index([countryCode, category])
}

// ============================================================================
// COST OF LIVING — Rent, food, transport, internet, healthcare
// ============================================================================

model CostOfLiving {
  id              String    @id @default(uuid())
  countryCode     String
  city            String?   // null = country average
  period          String    // "2025-Q1", "2025-03"
  rentIndex       Float?    // relative index (NYC = 100)
  groceriesIndex  Float?
  transportIndex  Float?
  healthcareIndex Float?
  overallIndex    Float?
  averageRent1br  Float?    // USD/month
  averageRent3br  Float?
  mealCost        Float?    // avg restaurant meal
  internetCost    Float?    // monthly broadband
  currency        String    @default("USD")
  sourceUrl       String?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  country Country @relation(fields: [countryCode], references: [code])

  @@index([countryCode])
  @@index([countryCode, city])
  @@unique([countryCode, city, period])
}

// ============================================================================
// STATISTICS — Migration flows, approval rates, processing times, diaspora
// ============================================================================

model Statistic {
  id              String    @id @default(uuid())
  countryCode     String
  category        String    // migration_flow, approval_rate, processing_time, diaspora, population
  metric          String    // "total_immigrants_2024", "h1b_approval_rate", etc.
  value           Float
  unit            String?   // "people", "percent", "months", "days"
  period          String    // "2025", "2025-Q1"
  comparison      Float?    // previous period value (for trend)
  sourceUrl       String?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  country Country @relation(fields: [countryCode], references: [code])

  @@index([countryCode])
  @@index([category])
  @@index([countryCode, category, period])
}

// ============================================================================
// LEGAL UPDATES — Changelog of law changes (feeds into Telegram + site)
// ============================================================================

model LegalUpdate {
  id               String    @id @default(uuid())
  countryCode      String
  category         String    // visa, labor, tax, housing, healthcare, education, asylum
  title            String
  summary          String
  details          String?   // longer markdown content
  impactLevel      String    @default("medium") // low, medium, high, critical
  effectiveDate    DateTime?
  sourceUrl        String?

  // Publication workflow
  workflowStatus   String    @default("raw")   // raw, draft, review, approved, published, archived
  assignedTo       String?                      // who's working on this
  reviewNote       String?                      // reviewer comment
  publishedContent String?                      // final edited text for publishing
  telegramPosted   Boolean   @default(false)    // legacy flag

  publishedAt      DateTime  @default(now())
  createdAt        DateTime  @default(now())

  country          Country   @relation(fields: [countryCode], references: [code])
  relationsFrom    UpdateRelation[] @relation("FromUpdate")
  relationsTo      UpdateRelation[] @relation("ToUpdate")
  distributions    Distribution[]
  articleSources   ArticleSource[]

  @@index([countryCode])
  @@index([category])
  @@index([publishedAt])
  @@index([telegramPosted])
  @@index([workflowStatus])
}

// ============================================================================
// UPDATE RELATIONS — Graph of related/causal news connections
// ============================================================================

model UpdateRelation {
  id           String   @id @default(uuid())
  fromId       String
  toId         String
  relationType String   // related, causes, caused_by, supersedes, part_of_series
  confidence   Float    @default(1.0) // 0.0-1.0 for auto-detected relations
  note         String?
  createdAt    DateTime @default(now())

  fromUpdate   LegalUpdate @relation("FromUpdate", fields: [fromId], references: [id])
  toUpdate     LegalUpdate @relation("ToUpdate", fields: [toId], references: [id])

  @@unique([fromId, toId])
  @@index([fromId])
  @@index([toId])
}

// ============================================================================
// DISTRIBUTION — Social media / channel posting tracker
// ============================================================================

model Distribution {
  id           String    @id @default(uuid())
  updateId     String
  channel      String    // telegram, twitter, instagram, linkedin, website
  status       String    @default("pending") // pending, sent, failed, deleted
  externalId   String?   // post ID in the social network
  externalUrl  String?   // link to the post
  sentAt       DateTime?
  errorMessage String?
  clicks       Int       @default(0)
  impressions  Int       @default(0)
  metadata     Json      @default("{}")
  createdAt    DateTime  @default(now())

  update       LegalUpdate @relation(fields: [updateId], references: [id])

  @@index([updateId])
  @@index([channel])
  @@index([status])
  @@unique([updateId, channel])
}

// ============================================================================
// AGENTS — AI journalist personas with configurable styles
// ============================================================================

model Agent {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String   @default("")  // public byline: "Sarah Mitchell"
  avatar      String?               // emoji avatar
  role        String   @default("journalist") // journalist, editor, reviewer
  basePrompt  String                // hardcoded journalist DNA
  stylePrompt String   @default("") // user-defined: tone, voice, quirks
  formatting  Json     @default("{}") // { length, useEmoji, headerStyle, etc }
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles    Article[]
}

// ============================================================================
// ARTICLES — Editorial content built from LegalUpdates
// ============================================================================

model Article {
  id              String    @id @default(uuid())
  slug            String    @unique
  title           String
  excerpt         String?
  body            String    @default("")
  bodyHtml        String?
  coverImage      String?

  tags            String[]
  region          String?
  category        String?               // frontend category slug: north-america, europe, schengen, etc.
  language        String    @default("en")

  status          String    @default("idea") // idea, outline, draft, review, approved, published, archived
  author          String?
  agentId         String?
  reviewer        String?
  reviewNote      String?
  needsResearch   Boolean   @default(false)
  researchNote    String?
  stageUpdatedAt  DateTime  @default(now()) // tracks when status last changed (for auto-progression)

  metaTitle       String?
  metaDescription String?

  publishedAt     DateTime?
  scheduledAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  agent           Agent?   @relation(fields: [agentId], references: [id])
  sources         ArticleSource[]
  distributions   ArticleDistribution[]

  @@index([status])
  @@index([publishedAt])
  @@index([language])
  @@index([category])
}

model ArticleSource {
  id         String   @id @default(uuid())
  articleId  String
  updateId   String
  role       String   @default("source") // source, main_topic, background, quote
  note       String?

  article    Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  update     LegalUpdate  @relation(fields: [updateId], references: [id])

  @@unique([articleId, updateId])
  @@index([articleId])
  @@index([updateId])
}

model ArticleDistribution {
  id           String    @id @default(uuid())
  articleId    String
  channel      String
  status       String    @default("pending")
  format       String    @default("full") // full, excerpt, link_only, thread
  externalId   String?
  externalUrl  String?
  sentAt       DateTime?
  errorMessage String?
  clicks       Int       @default(0)
  metadata     Json      @default("{}")
  createdAt    DateTime  @default(now())

  article      Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@unique([articleId, channel])
}

// ============================================================================
// DATA SOURCES — Registry of external data providers
// ============================================================================

model DataSource {
  id              String    @id @default(uuid())
  name            String    @unique  // "oecd", "eurostat", "numbeo", etc.
  type            String    // api, scraper, manual
  baseUrl         String
  description     String?
  frequency       String    // daily, weekly, monthly, quarterly, yearly
  countries       String[]  // ["US", "CA", "UK"] or ["*"] for all
  dataCategories  String[]  // ["cost_of_living", "statistics"]
  isActive        Boolean   @default(true)
  lastFetchedAt   DateTime?
  lastStatus      String?   // success, error, partial
  config          Json      @default("{}") // API keys, params, headers
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ============================================================================
// COLLECTION LOGS — Audit trail for data fetches
// ============================================================================

model CollectionLog {
  id              String    @id @default(uuid())
  sourceName      String
  status          String    // success, error, partial
  recordsAdded    Int       @default(0)
  recordsUpdated  Int       @default(0)
  recordsSkipped  Int       @default(0)
  errorMessage    String?
  durationMs      Int?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())

  @@index([sourceName])
  @@index([createdAt])
}

// ============================================================================
// SUBSCRIBER — Newsletter subscribers with topic preferences
// ============================================================================

model Subscriber {
  id            String    @id @default(uuid())
  email         String    @unique
  topics        String[]  // visas, labor, asylum, digital-nomad, cost-of-living, statistics
  lang          String    @default("en")
  verified      Boolean   @default(false)
  active        Boolean   @default(true)
  subscribedAt  DateTime  @default(now())
  unsubscribedAt DateTime?
  metadata      Json      @default("{}")

  @@index([active])
}

// ============================================================================
// USER — Registered users for comments & interactions
// ============================================================================

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String
  displayName    String
  role           String    @default("user")  // user, moderator, admin
  isActive       Boolean   @default(true)
  avatarUrl      String?
  telegramHandle String?               // @username for notifications
  bio            String?
  createdAt      DateTime  @default(now())
  lastLoginAt    DateTime?

  comments       Comment[]
  likes          Like[]
  bookmarks      Bookmark[]
  collections    Collection[]

  @@index([email])
}

// ============================================================================
// COMMENT — Article comments
// ============================================================================

model Comment {
  id        String    @id @default(uuid())
  body      String
  articleId String
  userId    String
  parentId  String?   // reply to another comment
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")

  @@index([articleId])
  @@index([userId])
  @@index([parentId])
}

// ============================================================================
// LIKE — Article likes (one per user per article)
// ============================================================================

model Like {
  id        String   @id @default(uuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([articleId])
}

// ============================================================================
// BOOKMARK — Saved articles, optionally in a collection
// ============================================================================

model Bookmark {
  id           String      @id @default(uuid())
  userId       String
  articleId    String
  collectionId String?
  createdAt    DateTime    @default(now())

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  @@unique([userId, articleId])
  @@index([userId])
  @@index([collectionId])
}

// ============================================================================
// COLLECTION — User-created folders for bookmarks
// ============================================================================

model Collection {
  id        String     @id @default(uuid())
  userId    String
  name      String
  color     String     @default("#a855f7")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookmarks Bookmark[]

  @@unique([userId, name])
  @@index([userId])
}

// ============================================================================
// CITY — Core entity for nomad data (200+ cities)
// ============================================================================

model City {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique              // "bangkok", "kuala-lumpur"
  countryCode   String
  lat           Float?
  lng           Float?
  population    Int?
  timezone      String?                       // "Asia/Bangkok"
  isCapital     Boolean  @default(false)
  nomadScore    Float?                        // composite 0-100
  description   String?                       // AI-generated city overview
  metadata      Json     @default("{}")       // flexible extra data
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  country        Country          @relation(fields: [countryCode], references: [code])
  prices         CityPrice[]
  housing        CityHousing[]
  climate        CityClimate[]
  infrastructure CityInfrastructure[]
  safety         CitySafety[]
  environment    CityEnvironment[]
  healthcare     CityHealthcare[]
  education      CityEducation[]
  lifestyle      CityLifestyle[]
  scores         NomadScore[]

  @@index([countryCode])
  @@index([nomadScore])
}

// ============================================================================
// CITY PRICE — Granular cost of living (Numbeo-style, 50+ items)
// ============================================================================

model CityPrice {
  id          String   @id @default(uuid())
  cityId      String
  category    String                          // restaurants, markets, transport, utilities, clothing, leisure, childcare
  item        String                          // "meal_inexpensive", "milk_1l", "metro_ticket", "cappuccino"
  value       Float
  currency    String   @default("USD")
  period      String                          // "2026-Q1"
  source      String?                         // "numbeo", "ai_enrichment", "teleport"
  confidence  Int      @default(5)            // 1-10 data quality
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  city        City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, item, period])
  @@index([cityId])
  @@index([category])
}

// ============================================================================
// CITY HOUSING — Rent, buy, Airbnb, short/mid/long-term
// ============================================================================

model CityHousing {
  id               String   @id @default(uuid())
  cityId           String
  type             String                     // "rent_1br_center", "rent_1br_outside", "rent_studio", "buy_sqm_center", "airbnb_month", "hostel_night"
  value            Float
  currency         String   @default("USD")
  furnished        Boolean  @default(true)    // furnished or not
  period           String                     // "2026-Q1"
  depositMonths    Float?                     // typical deposit in months
  foreignCanBuy    Boolean?                   // can foreigners buy property
  source           String?
  confidence       Int      @default(5)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  city             City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, type, period])
  @@index([cityId])
}

// ============================================================================
// CITY CLIMATE — Monthly averages (12 rows per city per year)
// ============================================================================

model CityClimate {
  id               String  @id @default(uuid())
  cityId           String
  month            Int                        // 1-12
  avgTempC         Float?                     // average temperature °C
  minTempC         Float?
  maxTempC         Float?
  avgHumidity      Float?                     // percent 0-100
  avgRainMm        Float?                     // mm per month
  rainyDays        Int?
  sunshineHours    Float?                     // hours per month
  uvIndex          Float?
  period           String                     // "2026"
  source           String?
  createdAt        DateTime @default(now())

  city             City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, month, period])
  @@index([cityId])
}

// ============================================================================
// CITY INFRASTRUCTURE — Internet, mobile, coworking, transport
// ============================================================================

model CityInfrastructure {
  id                  String   @id @default(uuid())
  cityId              String
  internetSpeedMbps   Float?                  // fixed broadband avg
  mobileSpeedMbps     Float?                  // 4G/5G avg
  coworkingCount      Int?                    // number of coworking spaces
  avgCoworkingDay     Float?                  // USD per day
  avgCoworkingMonth   Float?                  // USD per month
  hasUber             Boolean  @default(false)
  hasGrab             Boolean  @default(false)
  hasBolt             Boolean  @default(false)
  hasMetro            Boolean  @default(false)
  simCard10gb         Float?                  // cost of SIM with 10GB data
  digitalReadiness    Int?                    // 1-10 score: banking, Wise, delivery apps
  period              String
  source              String?
  confidence          Int      @default(5)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  city                City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, period])
  @@index([cityId])
}

// ============================================================================
// CITY SAFETY — Crime, scams, women safety, LGBTQ+
// ============================================================================

model CitySafety {
  id                  String   @id @default(uuid())
  cityId              String
  crimeIndex          Float?                  // 0-100 (higher = more crime)
  safetyIndex         Float?                  // 0-100 (higher = safer)
  walkingDaySafety    Int?                    // 1-10
  walkingNightSafety  Int?                    // 1-10
  womenSafety         Int?                    // 1-10
  lgbtqFriendly       Int?                    // 1-10
  scamRisk            Int?                    // 1-10 (higher = more scams)
  corruptionIndex     Float?                  // 0-100
  period              String
  source              String?
  confidence          Int      @default(5)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  city                City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, period])
  @@index([cityId])
}

// ============================================================================
// CITY ENVIRONMENT — Air quality, water, noise, green areas
// ============================================================================

model CityEnvironment {
  id               String   @id @default(uuid())
  cityId           String
  aqiIndex         Float?                     // Air Quality Index (0-500)
  pm25             Float?                     // PM2.5 μg/m³
  waterQuality     Int?                       // 1-10
  noiseLevel       Int?                       // 1-10
  greenSpaceScore  Int?                       // 1-10
  pollutionIndex   Float?                     // 0-100
  period           String
  source           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  city             City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, period])
  @@index([cityId])
}

// ============================================================================
// CITY HEALTHCARE — Medical quality, costs, insurance
// ============================================================================

model CityHealthcare {
  id                  String   @id @default(uuid())
  cityId              String
  qualityIndex        Int?                    // 1-10
  hospitalBedsPer1k   Float?                  // beds per 1000 people
  doctorVisitCost     Float?                  // USD, general practitioner
  dentistVisitCost    Float?                  // USD
  emergencyVisitCost  Float?                  // USD, ER visit
  monthlyInsurance    Float?                  // USD, private health insurance
  pharmacyAccess      Int?                    // 1-10
  englishDoctors      Int?                    // 1-10, availability of English-speaking doctors
  period              String
  source              String?
  confidence          Int      @default(5)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  city                City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, period])
  @@index([cityId])
}

// ============================================================================
// CITY EDUCATION — Schools, universities, language
// ============================================================================

model CityEducation {
  id                    String   @id @default(uuid())
  cityId                String
  internationalSchools  Int?                  // count
  avgTuitionYear        Float?                // USD per year
  universityRanking     Int?                  // best university world rank
  englishProficiency    Int?                  // 1-10 (EF EPI based)
  languageBarrier       Int?                  // 1-10 (1 = easy, 10 = hard)
  period                String
  source                String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  city                  City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, period])
  @@index([cityId])
}

// ============================================================================
// CITY LIFESTYLE — Coworking scene, cafes, nightlife, expat community
// ============================================================================

model CityLifestyle {
  id                 String   @id @default(uuid())
  cityId             String
  cafeScene          Int?                     // 1-10
  nightlife          Int?                     // 1-10
  gymMonthly         Float?                   // USD per month
  fitnessAccess      Int?                     // 1-10
  expatCommunity     Int?                     // 1-10 (size & activity)
  meetupScene        Int?                     // 1-10
  culturalEvents     Int?                     // 1-10
  foodScene          Int?                     // 1-10
  familyFriendly     Int?                     // 1-10
  petFriendly        Int?                     // 1-10
  petQuarantine      Boolean?                 // does country require pet quarantine
  avgVetVisit        Float?                   // USD, vet consultation
  period             String
  source             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  city               City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, period])
  @@index([cityId])
}

// ============================================================================
// NOMAD SCORE — Composite score with sub-scores (recalculated on data update)
// ============================================================================

model NomadScore {
  id                String   @id @default(uuid())
  cityId            String
  overall           Float                     // 0-100 composite
  costScore         Float?                    // 0-100
  housingScore      Float?                    // 0-100
  internetScore     Float?                    // 0-100
  safetyScore       Float?                    // 0-100
  climateScore      Float?                    // 0-100
  healthcareScore   Float?                    // 0-100
  environmentScore  Float?                    // 0-100
  lifestyleScore    Float?                    // 0-100
  educationScore    Float?                    // 0-100
  infraScore        Float?                    // 0-100 (digital readiness + transport)
  period            String                    // "2026-Q1"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  city              City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, period])
  @@index([cityId])
  @@index([overall])
}
